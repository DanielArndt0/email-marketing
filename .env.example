# =========================================================
# Ambiente da aplicação
# =========================================================
# Define o ambiente de execução da aplicação.
# Valores esperados:
# - development
# - test
# - production
NODE_ENV=development

# =========================================================
# Logs
# =========================================================
# Nível de log da aplicação.
# Valores aceitos:
# fatal, error, warn, info, debug, trace, silent
LOG_LEVEL=info

# =========================================================
# API HTTP
# =========================================================
# Porta em que a Control API será iniciada localmente.
API_PORT=3333

# CORS
# Separe múltiplas origens por vírgula.
# Exemplo: http://localhost:3000,http://localhost:5173
CORS_ORIGINS=http://localhost:3000

# =========================================================
# PostgreSQL
# =========================================================
# Host do banco PostgreSQL.
POSTGRES_HOST=localhost

# Porta do PostgreSQL.
POSTGRES_PORT=5432

# Nome do banco de dados da aplicação.
POSTGRES_DB=email_marketing

# Usuário do banco PostgreSQL.
POSTGRES_USER=postgres

# Senha do banco PostgreSQL.
POSTGRES_PASSWORD=postgres

# =========================================================
# Redis
# =========================================================
# Host do Redis.
REDIS_HOST=localhost

# Porta do Redis.
REDIS_PORT=6379

# =========================================================
# SMTP / E-mail
# =========================================================
# Host do servidor SMTP.
SMTP_HOST=localhost

# Porta do servidor SMTP.
SMTP_PORT=1025

# Define se a conexão SMTP usa TLS/SSL direto.
# Valores aceitos:
# - true
# - false
SMTP_SECURE=false

# Usuário de autenticação SMTP.
# Pode ficar vazio em ambiente local/fake SMTP.
SMTP_USER=

# Senha de autenticação SMTP.
# Pode ficar vazio em ambiente local/fake SMTP.
SMTP_PASSWORD=

# Nome padrão do remetente.
SMTP_FROM_NAME=Mail Engine

# E-mail padrão do remetente.
SMTP_FROM_EMAIL=no-reply@example.com

# =========================================================
# CNPJ API / Lead Source
# =========================================================
# URL base da CNPJ API utilizada como fonte de leads.
CNPJ_API_BASE_URL=http://localhost:3000

# Token opcional de autenticação da CNPJ API.
# Pode ficar vazio enquanto a integração local não exigir autenticação.
CNPJ_API_TOKEN=

# Timeout máximo, em milissegundos, para chamadas à CNPJ API.
CNPJ_API_TIMEOUT_MS=10000
