# =========================================================
# Ambiente da aplicação
# =========================================================
# Define o ambiente de execução da aplicação dentro do Docker.
# Valores esperados:
# - development
# - test
# - production
NODE_ENV=development

# =========================================================
# Logs
# =========================================================
# Nível de log da aplicação.
# Valores aceitos:
# fatal, error, warn, info, debug, trace, silent
LOG_LEVEL=info

# =========================================================
# API HTTP
# =========================================================
# Porta interna em que a Control API será iniciada dentro do container.
API_PORT=3333

# CORS
# Separe múltiplas origens por vírgula.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3333

# =========================================================
# PostgreSQL
# =========================================================
# Host do banco PostgreSQL dentro da rede do Docker Compose.
# Deve ser igual ao nome do serviço no compose.yml.
POSTGRES_HOST=postgres

# Porta interna do PostgreSQL dentro do container.
POSTGRES_PORT=5432

# Nome do banco de dados da aplicação.
POSTGRES_DB=email_marketing

# Usuário do banco PostgreSQL usado no container.
POSTGRES_USER=email_marketing

# Senha do banco PostgreSQL usada no container.
POSTGRES_PASSWORD=email_marketing

# =========================================================
# Redis
# =========================================================
# Host do Redis dentro da rede do Docker Compose.
# Deve ser igual ao nome do serviço no compose.yml.
REDIS_HOST=redis

# Porta interna do Redis dentro do container.
REDIS_PORT=6379

# =========================================================
# SMTP / E-mail
# =========================================================
# Chave de criptografia para dados sensíveis relacionados ao SMTP.
# Troque este valor no seu .env.docker real.
SMTP_SENDER_ENCRYPTION_KEY=secret-key-with-at-least-32-chars

# =========================================================
# CNPJ API / Lead Source
# =========================================================
# URL base da CNPJ API utilizada como fonte de leads.
CNPJ_API_BASE_URL=http://host.docker.internal:3000

# Token opcional de autenticação da CNPJ API.
# Pode ficar vazio enquanto a integração local não exigir autenticação.
CNPJ_API_TOKEN=

# Timeout máximo, em milissegundos, para chamadas à CNPJ API.
CNPJ_API_TIMEOUT_MS=10000